# ============================================================
# AI Dev Agency — Environment Configuration
# Copy this to .env and fill in your keys
# ============================================================

# --- Core LLM (used by CrewAI for all agents) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx          # fallback / optional

# --- Phase 1: Scout (Lead Generation) ---
APIFY_API_TOKEN=apify_api_xxxxx
# OR
BROWSE_AI_API_KEY=xxxxx

# --- Phase 3: Closer (CRM / Email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=agency@yourdomain.com
SMTP_PASSWORD=xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx

# --- Phase 4: Builder (Code Gen + Deploy) ---
DATABASE_URL=postgresql://user:password@host:5432/aiagency
VERCEL_TOKEN=xxxxx
RAILWAY_TOKEN=xxxxx
GITHUB_TOKEN=ghp_xxxxx

# --- Phase 5: Auditor (QA) ---
BROWSERSTACK_USER=xxxxx
BROWSERSTACK_KEY=xxxxx

# --- n8n Webhook (glue between n8n ↔ CrewAI) ---
N8N_WEBHOOK_URL=http://localhost:5678/webhook/new-lead
CREWAI_CALLBACK_URL=http://localhost:8000/api/pipeline/result

# --- Online deployment controls ---
AUTO_PIPELINE_INTERVAL_MINUTES=0
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
